{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strataos/policy.schema.json",
  "title": "Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "weights", "thresholds", "constraints", "version"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "weights": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "operator", "value"],
        "properties": {
          "key": { "type": "string" },
          "operator": { "type": "string", "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "in", "not_in"] },
          "value": {}
        }
      }
    },
    "version": { "type": "integer", "minimum": 1 }
  }
}
