{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strataos/recommendation.schema.json",
  "title": "Recommendation",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision_id", "decision_model_version", "action", "summary", "drivers"],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "decision_model_version": { "type": "string", "minLength": 1 },
    "action": {
      "type": "string",
      "enum": [
        "APPLY_IMMEDIATELY",
        "HIGH_PRIORITY_REVIEW",
        "NETWORK_FIRST",
        "MONITOR",
        "IGNORE",
        "RESEARCH_COMPANY"
      ]
    },
    "summary": { "type": "string", "minLength": 1 },
    "drivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["direction", "message", "claim_ref"],
        "properties": {
          "direction": { "type": "string", "enum": ["positive", "negative"] },
          "message": { "type": "string", "minLength": 1 },
          "claim_ref": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
