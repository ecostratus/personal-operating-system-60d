{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strataos/evidence.schema.json",
  "title": "Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "person_id",
    "opportunity_id",
    "observation_ids",
    "kind",
    "quality",
    "provenance"
  ],
  "properties": {
    "evidence_id": { "type": "string", "minLength": 1 },
    "person_id": { "type": "string", "minLength": 1 },
    "opportunity_id": { "type": "string", "minLength": 1 },
    "observation_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "kind": { "type": "string", "minLength": 1 },
    "quality": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "captured_at",
        "parser",
        "normalizer",
        "evidence_builder",
        "claim_generator"
      ],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "captured_at": { "type": "string", "format": "date-time" },
        "parser": { "type": "string", "minLength": 1 },
        "normalizer": { "type": "string", "minLength": 1 },
        "evidence_builder": { "type": "string", "minLength": 1 },
        "claim_generator": { "type": "string", "minLength": 1 }
      }
    }
  }
}
